<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.ImageView?>

<AnchorPane prefHeight="700.0" prefWidth="1000.0" style="-fx-background-color: #f5f6fa;"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.controller.MainController">

    <TabPane tabClosingPolicy="UNAVAILABLE" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0"
             style="-fx-tab-min-width: 200; -fx-tab-min-height: 50;">
        <tabs>
            <Tab text="📦 КАТАЛОГ ТОВАРОВ">
                <HBox spacing="0">
                    <VBox spacing="15" prefWidth="400" style="-fx-background-color: white; -fx-padding: 20; -fx-border-color: #dcdde1; -fx-border-width: 0 1 0 0;">
                        <Label text="Комплектующие для окон" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2f3640;"/>
                        <ListView fx:id="productList" VBox.vgrow="ALWAYS"
                                  style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-padding: 5;"/>
                        <Button text="ПЕРЕЙТИ К ОПЛАТЕ" onAction="#handleBuy" maxWidth="Infinity"
                                style="-fx-background-color: #44bd32; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 15; -fx-background-radius: 10;"/>
                    </VBox>

                    <VBox alignment="TOP_CENTER" spacing="20" HBox.hgrow="ALWAYS" style="-fx-padding: 40;">
                        <ImageView fx:id="productImage" fitWidth="400.0" preserveRatio="true" />
                        <VBox spacing="10">
                            <Label fx:id="productTitle" text="Выберите позицию" style="-fx-font-size: 26px; -fx-font-weight: bold;"/>
                            <Separator />
                            <Label fx:id="productDescription" wrapText="true" style="-fx-font-size: 16px; -fx-text-fill: #718093; -fx-line-spacing: 5;"/>
                        </VBox>
                    </VBox>
                </HBox>
            </Tab>

            <Tab text="👤 ЛИЧНЫЙ КАБИНЕТ">
                <StackPane>
                    <VBox alignment="CENTER" spacing="20" maxWidth="500" maxHeight="400"
                          style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 40; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 15, 0, 0, 5);">
                        <Label fx:id="statusLabel" text="ПРОФИЛЬ ИП" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #353b48;"/>

                        <GridPane vgap="15" hgap="10">
                            <Label text="ФИО:" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-text-fill: #7f8c8d;"/>
                            <Label fx:id="nameLabel" text="..." GridPane.columnIndex="1" GridPane.rowIndex="0" style="-fx-font-weight: bold;"/>

                            <Label text="Дата рожд.:" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-text-fill: #7f8c8d;"/>
                            <Label fx:id="birthDateLabel" text="..." GridPane.columnIndex="1" GridPane.rowIndex="1" style="-fx-font-weight: bold;"/>

                            <Label text="Статус:" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-text-fill: #7f8c8d;"/>
                            <Label fx:id="statusIPLabel" text="..." GridPane.columnIndex="1" GridPane.rowIndex="2" style="-fx-text-fill: #2ecc71; -fx-font-weight: bold;"/>
                        </GridPane>

                        <Button text="Редактировать данные" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-background-radius: 5;"/>
                    </VBox>
                </StackPane>
            </Tab>
        </tabs>
    </TabPane>
</AnchorPane>